# macOS
.DS_Store

# Editors
.vscode/
.idea/
*.swp
*.swo
*~

# Claude Code (local/user-scoped)
.claude/settings.local.json

# Compound Engineering (machine-local config)
.compound-engineering/*.local.yaml

# ce:review run artifacts (ephemeral per-run JSON from reviewer subagents)
.context/

# Plugin-local test state (atomic-write tmp files, error logs, caches)
*.tmp
*.log
.cache/

# Node (defensive — we don't currently use Node, but future tooling may)
node_modules/

# Environment
.env
.env.local
.env.*.local

# Test infrastructure (installed, not committed)
tests/bats-core/

# Test output
coverage/
tests/output/

# Live-session smoke artifacts (generated locally by .smoke-run.sh;
# contain payload captures and machine paths not meant for the repo)
.smoke/
.smoke-run.sh
